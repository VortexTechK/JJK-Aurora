	<element name="Breakthrough 1" type="Item" source="JJK" id="ID_JJK_ITEM_IF_BREAKTHROUGH1">
		<compendium display="false" />
		<description>
			<p><i>You can equip this item to “enable” it. It remains hidden from the inventory on your character sheet.</i></p>
			<div class="reference">
				<div element="ID_JJK_CLASS_FEATURE_BREAKTHROUGH1" />
			</div>
		</description>
		<setters>
			<set name="category">JJK Extra Features</set>
			<set name="slot">misc</set>
			<set name="inventory-hidden">true</set>
		</setters>
		<rules>
			<grant type="Class Feature" id="ID_JJK_CLASS_FEATURE_BREAKTHROUGH1" requirements="[level:1]"/>
		</rules>
	</element>

