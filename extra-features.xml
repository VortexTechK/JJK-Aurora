<?xml version="1.0" encoding="utf-8" ?>
<elements>
	<info>
		<name>Extra Features</name>
		<description>The Extra Features from JJK</description>
		<author url="https://docs.google.com/document/d/1rxBzDsWgUR3gqeDADvCE5Zo1obYoBnwdNZXxmQdheP0/edit?tab=t.0">JJK</author>
		<update version="5.875">
			<file name="extra-features.xml" url="https://raw.githubusercontent.com/VortexTechK/JJK-Aurora/refs/heads/main/extra-features.xml" />
		</update>
	</info>
	<!-- Curse Energy -->
	<element name="Curse Energy" type="Class Feature" source="JJK" id="ID_JJK_CLASS_FEATURE_CURSED_ENERGY">
		<description>
			<p>Starting at 1st level, you can harness your negative feelings into a usable source of energy, called cursed energy. These feelings can be harnessed into attacks or abilities. The number of cursed energy you possess is based on your highest level class. You have a curse stat equal to the highest among charisma and wisdom.</p>
      		<p class="indent">Your cursed energy DC is 8 + user cursed energy ability modifier + proficiency bonus. </p>
		</description>
		<sheet>
			<description>You have {{ce:points:total}} Cursed Energy and your Cursed Energy DC is {{ce:dc:total}}. Your curse stat is {{cu:stat}}</description>
		</sheet>
        <rules>
            <!-- curse ability modifier (highest of Cha/Wis) -->
            <stat name="ce:modifier" value="charisma:modifier" bonus="cursed energy" />
            <stat name="ce:modifier" value="wisdom:modifier" bonus="cursed energy" />

            <!-- pure class-level anchors (used only for comparisons) -->
			<stat name="classlvljuggernaut" value="0" bonus="cursed energy" />
			<stat name="classlvlscout" value="0" bonus="cursed energy" />
			<stat name="classlvlshikigami" value="0" bonus="cursed energy" />
			<stat name="classlvlstrategist" value="0" bonus="cursed energy" />
			<stat name="classlvlsupport" value="0" bonus="cursed energy" />
			<stat name="classlvlwarrior" value="0" bonus="cursed energy" />
			<grant type="Class Feature" id="ID_JJK_CLASS_FEATURE_LEVEL_JUGGERNAUT" />
			<grant type="Class Feature" id="ID_JJK_CLASS_FEATURE_LEVEL_SCOUT" />
			<grant type="Class Feature" id="ID_JJK_CLASS_FEATURE_LEVEL_SHIKIGAMI" />
			<grant type="Class Feature" id="ID_JJK_CLASS_FEATURE_LEVEL_STRATEGIST" />
			<grant type="Class Feature" id="ID_JJK_CLASS_FEATURE_LEVEL_SUPPORT" />
			<grant type="Class Feature" id="ID_JJK_CLASS_FEATURE_LEVEL_WARRIOR" />

            <!-- class-specific CE base values (do NOT use these for comparisons) -->
            <stat name="ce:base_juggernaut" value="level" requirements="ID_JJK_CLASS_JUGGERNAUT||ID_JJK_MULTICLASS_JUGGERNAUT" />
            <stat name="ce:base_scout" value="level" requirements="ID_JJK_CLASS_SCOUT||ID_JJK_MULTICLASS_SCOUT" />
            <stat name="ce:base_shikigami" value="level" requirements="ID_JJK_CLASS_SHIKIGAMI_USER||ID_JJK_MULTICLASS_SHIKIGAMI_USER" />
            <!-- strategist: CE base = twice their strategist class level -->
            <stat name="ce:base_strategist" value="level" requirements="ID_JJK_CLASS_STRATEGIST||ID_JJK_MULTICLASS_STRATEGIST" />
			<stat name="ce:base_strategist" value="level" requirements="ID_JJK_CLASS_STRATEGIST||ID_JJK_MULTICLASS_STRATEGIST" />
            <!-- support: base = their support class level (proficiency added separately, see below) -->
            <stat name="ce:base_support" value="level" requirements="ID_JJK_CLASS_SUPPORT_SPECIALIST||ID_JJK_MULTICLASS_SUPPORT_SPECIALIST" />
			<stat name="ce:base_support" value="proficiency" requirements="ID_JJK_CLASS_SUPPORT_SPECIALIST||ID_JJK_MULTICLASS_SUPPORT_SPECIALIST" />
            <stat name="ce:base_warrior" value="level" requirements="ID_JJK_CLASS_WARRIOR||ID_JJK_MULTICLASS_WARRIOR" />

            <!-- choose base CE from the class whose CLASS LEVEL is highest (comparisons use classlvl*) -->
            <stat name="ce:points" value="ce:base_juggernaut" requirements="(ID_JJK_CLASS_JUGGERNAUT||ID_JJK_MULTICLASS_JUGGERNAUT),[classlvljuggernaut:classlvlscout],[classlvljuggernaut:classlvlshikigami],[classlvljuggernaut:classlvlstrategist],[classlvljuggernaut:classlvlsupport],[classlvljuggernaut:classlvlwarrior]" bonus="cursed energy" />
            <stat name="ce:points" value="ce:base_scout" requirements="(ID_JJK_CLASS_SCOUT||ID_JJK_MULTICLASS_SCOUT),[classlvlscout:classlvljuggernaut],[classlvlscout:classlvlshikigami],[classlvlscout:classlvlstrategist],[classlvlscout:classlvlsupport],[classlvlscout:classlvlwarrior]" bonus="cursed energy" />
            <stat name="ce:points" value="ce:base_shikigami" requirements="(ID_JJK_CLASS_SHIKIGAMI_USER||ID_JJK_MULTICLASS_SHIKIGAMI_USER),[classlvlshikigami:classlvljuggernaut],[classlvlshikigami:classlvlscout],[classlvlshikigami:classlvlstrategist],[classlvlshikigami:classlvlsupport],[classlvlshikigami:classlvlwarrior]" bonus="cursed energy" />
            <stat name="ce:points" value="ce:base_strategist" requirements="(ID_JJK_CLASS_STRATEGIST||ID_JJK_MULTICLASS_STRATEGIST),[classlvlstrategist:classlvljuggernaut],[classlvlstrategist:classlvlscout],[classlvlstrategist:classlvlshikigami],[classlvlstrategist:classlvlsupport],[classlvlstrategist:classlvlwarrior]" bonus="cursed energy" />
            <stat name="ce:points" value="ce:base_support" requirements="(ID_JJK_CLASS_SUPPORT_SPECIALIST||ID_JJK_MULTICLASS_SUPPORT_SPECIALIST),[classlvlsupport:classlvljuggernaut],[classlvlsupport:classlvlscout],[classlvlsupport:classlvlshikigami],[classlvlsupport:classlvlstrategist],[classlvlsupport:classlvlwarrior]" bonus="cursed energy" />
            <stat name="ce:points" value="ce:base_warrior" requirements="(ID_JJK_CLASS_WARRIOR||ID_JJK_MULTICLASS_WARRIOR),[classlvlwarrior:classlvljuggernaut],[classlvlwarrior:classlvlscout],[classlvlwarrior:classlvlshikigami],[classlvlwarrior:classlvlstrategist],[classlvlwarrior:classlvlsupport]" bonus="cursed energy" /> 

            <!-- add curse ability modifier -->
            <stat name="ce:points" value="ce:modifier" />

            <!-- final CE shown on sheet -->
            <stat name="ce:points:total" value="ce:points" />

            <!-- DC = 8 + proficiency + curse modifier -->
            <stat name="ce:dc" value="8" />
            <stat name="ce:dc" value="proficiency" />
            <stat name="ce:dc" value="ce:modifier" />
            <stat name="ce:dc:total" value="ce:dc" bonus="cursed energy" />

            <!-- curse stat = highest of Cha / Wis -->
            <stat name="cu:stat" value="charisma:score" bonus="cursed energy"/>			
            <stat name="cu:stat" value="wisdom:score" bonus="cursed energy" />
        </rules>
	</element>
